# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
__pycache__/
*.py[cod]
.venv-rst/
.cache/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# copied assets
/public/posts/
/public/books/
/public/series/
/public/flows/
/public/notes/

# pagefind index (generated after build)
/public/pagefind/

# knowledge graph (generated at build time)
/public/knowledge-graph.json

# image optimization
/public/**/nextImageExportOptimizer/
!/public/next-image-export-optimizer-hashes.json

# claude
/.claude/

# raw import files (chat exports, PDFs, etc.) — not published content
/imports/*
!/imports/README.md
